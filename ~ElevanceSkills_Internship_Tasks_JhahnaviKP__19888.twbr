    <worksheet name='Task1'>
      <table>
        <view>
          <datasources>
            <datasource caption='job_descriptions' name='federated.18l6cju1szvabd12b7oxa15df5ha' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Current_Hour' datatype='integer' name='[Parameter 1]' param-domain-type='any' role='measure' type='quantitative' value='15'>
              <calculation class='tableau' formula='15' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.18l6cju1szvabd12b7oxa15df5ha'>
            <column caption='Country_Not_ABCD' datatype='boolean' name='[Calculation_0437092124459008]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT (&#13;&#10;STARTSWITH([Country],&quot;A&quot;) OR&#13;&#10;STARTSWITH([Country],&quot;B&quot;) OR&#13;&#10;STARTSWITH([Country],&quot;C&quot;) OR&#13;&#10;STARTSWITH([Country],&quot;D&quot;)&#13;&#10;)' />
            </column>
            <column caption='JobTitle_SingleWord' datatype='boolean' name='[Calculation_0437092124909569]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT CONTAINS([Job Title], &quot; &quot;)' />
            </column>
            <column caption='JobTitle_Less10' datatype='boolean' name='[Calculation_0437092125093890]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN([Job Title]) &lt; 10' />
            </column>
            <column caption='Salary_Min' datatype='integer' name='[Calculation_0437092125769731]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#13;&#10;&quot;$&quot;,&quot;&quot;&#13;&#10;),&#13;&#10;&quot;K&quot;,&quot;000&quot;&#13;&#10;)&#13;&#10;)' />
            </column>
            <column caption='Experience_Num' datatype='integer' name='[Calculation_0437092127428614]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(&#13;&#10;IFNULL(&#13;&#10;REGEXP_EXTRACT([Experience], &quot;(\\d+)&quot;),&#13;&#10;&quot;0&quot;&#13;&#10;)&#13;&#10;)' />
            </column>
            <column caption='Experience_Even' datatype='boolean' name='[Calculation_0437092127526919]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_0437092127428614] % 2 = 0' />
            </column>
            <column caption='Odd_Month' datatype='boolean' name='[Calculation_0437092127961096]' role='dimension' type='nominal'>
