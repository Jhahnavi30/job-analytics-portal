              <calculation class='tableau' formula='IF [Country] = &quot;Asia&quot; THEN &quot;NO&quot;&#13;&#10;ELSEIF LEFT([Country],1) = &quot;C&quot; THEN &quot;NO&quot;&#13;&#10;ELSE &quot;YES&quot;&#13;&#10;END' />
