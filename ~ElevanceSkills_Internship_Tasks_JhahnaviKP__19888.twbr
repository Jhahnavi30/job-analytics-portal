      <aliases enabled='yes' />
      <column caption='Country_Not_ABCD' datatype='boolean' name='[Calculation_0437092124459008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT (&#13;&#10;STARTSWITH([Country],&quot;A&quot;) OR&#13;&#10;STARTSWITH([Country],&quot;B&quot;) OR&#13;&#10;STARTSWITH([Country],&quot;C&quot;) OR&#13;&#10;STARTSWITH([Country],&quot;D&quot;)&#13;&#10;)' />
      </column>
      <column caption='JobTitle_SingleWord' datatype='boolean' name='[Calculation_0437092124909569]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT CONTAINS([Job Title], &quot; &quot;)' />
      </column>
      <column caption='JobTitle_Less10' datatype='boolean' name='[Calculation_0437092125093890]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN([Job Title]) &lt; 10' />
      </column>
      <column caption='Salary_Min' datatype='integer' name='[Calculation_0437092125769731]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#13;&#10;&quot;$&quot;,&quot;&quot;&#13;&#10;),&#13;&#10;&quot;K&quot;,&quot;000&quot;&#13;&#10;)&#13;&#10;)' />
      </column>
      <column caption='Experience_Num' datatype='integer' name='[Calculation_0437092127428614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#13;&#10;IFNULL(&#13;&#10;REGEXP_EXTRACT([Experience], &quot;(\\d+)&quot;),&#13;&#10;&quot;0&quot;&#13;&#10;)&#13;&#10;)' />
      </column>
      <column caption='Experience_Even' datatype='boolean' name='[Calculation_0437092127526919]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0437092127428614] % 2 = 0' />
      </column>
      <column caption='Odd_Month' datatype='boolean' name='[Calculation_0437092127961096]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;month&apos;,[Job Posting Date]) % 2 = 1' />
      </column>
      <column caption='Experience_Clean' datatype='string' name='[Calculation_0437092173271058]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REPLACE(REPLACE(LOWER([Experience]), &quot;years&quot;, &quot;&quot;), &quot;year&quot;, &quot;&quot;)' />
      </column>
      <column caption='Experience_Min' datatype='integer' name='[Calculation_0437092173340691]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(SPLIT([Calculation_0437092173271058], &quot; &quot;, 1))' />
      </column>
      <column caption='Experience_Max' datatype='integer' name='[Calculation_0437092173410324]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(SPLIT([Calculation_0437092173271058], &quot; &quot;, 3))' />
      </column>
      <column caption='Asia_Not_I' datatype='string' name='[Calculation_0437092181155861]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] IN (&quot;India&quot;,&quot;Indonesia&quot;,&quot;Iran&quot;,&quot;Iraq&quot;,&quot;Israel&quot;) THEN &quot;NO&quot;&#13;&#10;&#13;&#10;ELSEIF [Country] IN (&#13;&#10;&quot;Afghanistan&quot;,&quot;Armenia&quot;,&quot;Azerbaijan&quot;,&quot;Bahrain&quot;,&quot;Bangladesh&quot;,&quot;Bhutan&quot;,&quot;Brunei&quot;,&#13;&#10;&quot;Cambodia&quot;,&quot;China&quot;,&quot;Cyprus&quot;,&quot;Georgia&quot;,&quot;Japan&quot;,&quot;Jordan&quot;,&quot;Kazakhstan&quot;,&quot;Kuwait&quot;,&#13;&#10;&quot;Kyrgyzstan&quot;,&quot;Laos&quot;,&quot;Lebanon&quot;,&quot;Malaysia&quot;,&quot;Maldives&quot;,&quot;Mongolia&quot;,&quot;Myanmar&quot;,&#13;&#10;&quot;Nepal&quot;,&quot;North Korea&quot;,&quot;Oman&quot;,&quot;Pakistan&quot;,&quot;Palestine&quot;,&quot;Philippines&quot;,&quot;Qatar&quot;,&#13;&#10;&quot;Russia&quot;,&quot;Saudi Arabia&quot;,&quot;Singapore&quot;,&quot;South Korea&quot;,&quot;Sri Lanka&quot;,&quot;Syria&quot;,&quot;Taiwan&quot;,&#13;&#10;&quot;Tajikistan&quot;,&quot;Thailand&quot;,&quot;Timor-Leste&quot;,&quot;Turkey&quot;,&quot;Turkmenistan&quot;,&#13;&#10;&quot;United Arab Emirates&quot;,&quot;Uzbekistan&quot;,&quot;Vietnam&quot;,&quot;Yemen&quot;&#13;&#10;)&#13;&#10;THEN &quot;YES&quot;&#13;&#10;&#13;&#10;ELSE &quot;NO&quot;&#13;&#10;END' />
      </column>
      <column caption='Company_2Vowels' datatype='boolean' name='[Calculation_0437092181778454]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='(&#13;&#10;LEN(REGEXP_REPLACE(LOWER([Company]), &quot;[^aeiou]&quot;, &quot;&quot;))&#13;&#10;) &gt;= 2' />
      </column>
      <column caption='Country_Task3' datatype='string' name='[Calculation_0975578719219712]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] = &quot;Asia&quot; THEN &quot;NO&quot;&#13;&#10;ELSEIF LEFT([Country],1) = &quot;C&quot; THEN &quot;NO&quot;&#13;&#10;ELSE &quot;YES&quot;&#13;&#10;END' />
      </column>
      <column caption='country_c' datatype='string' name='[Calculation_0975578730475523]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([Country],1) = &quot;C&quot; THEN &quot;NO&quot;&#13;&#10;&#13;&#10;ELSEIF [Country] IN (&#13;&#10;&quot;Afghanistan&quot;,&quot;Armenia&quot;,&quot;Azerbaijan&quot;,&quot;Bahrain&quot;,&quot;Bangladesh&quot;,&quot;Bhutan&quot;,&quot;Brunei&quot;,&#13;&#10;&quot;Cambodia&quot;,&quot;China&quot;,&quot;Cyprus&quot;,&quot;Georgia&quot;,&quot;India&quot;,&quot;Indonesia&quot;,&quot;Iran&quot;,&quot;Iraq&quot;,&quot;Israel&quot;,&#13;&#10;&quot;Japan&quot;,&quot;Jordan&quot;,&quot;Kazakhstan&quot;,&quot;Kuwait&quot;,&quot;Kyrgyzstan&quot;,&quot;Laos&quot;,&quot;Lebanon&quot;,&quot;Malaysia&quot;,&#13;&#10;&quot;Maldives&quot;,&quot;Mongolia&quot;,&quot;Myanmar&quot;,&quot;Nepal&quot;,&quot;North Korea&quot;,&quot;Oman&quot;,&quot;Pakistan&quot;,&#13;&#10;&quot;Palestine&quot;,&quot;Philippines&quot;,&quot;Qatar&quot;,&quot;Russia&quot;,&quot;Saudi Arabia&quot;,&quot;Singapore&quot;,&#13;&#10;&quot;South Korea&quot;,&quot;Sri Lanka&quot;,&quot;Syria&quot;,&quot;Taiwan&quot;,&quot;Tajikistan&quot;,&quot;Thailand&quot;,&quot;Timor-Leste&quot;,&#13;&#10;&quot;Turkey&quot;,&quot;Turkmenistan&quot;,&quot;United Arab Emirates&quot;,&quot;Uzbekistan&quot;,&quot;Vietnam&quot;,&quot;Yemen&quot;&#13;&#10;) THEN &quot;NO&quot;&#13;&#10;&#13;&#10;ELSE &quot;YES&quot;&#13;&#10;END' />
      </column>
      <column caption='Contact_End_Vowel' datatype='string' name='[Calculation_0975578731040772]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF RIGHT(LOWER([Contact Person]),1) IN (&quot;a&quot;,&quot;e&quot;,&quot;i&quot;,&quot;o&quot;,&quot;u&quot;) THEN &quot;YES&quot;&#13;&#10;ELSE &quot;NO&quot;&#13;&#10;END' />
      </column>
      <column caption='Contact_Has_E' datatype='boolean' name='[Calculation_1010215822696449]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS(LOWER([Contact Person]), &quot;e&quot;)' />
      </column>
      <column caption='Location_NotBlank' datatype='boolean' name='[Calculation_1058867737047040]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([location]) AND TRIM([location]) &lt;&gt; &quot;&quot;' />
      </column>
      <column caption='CompanyName_Length' datatype='boolean' name='[Calculation_1058867738353665]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN(TRIM([Company])) &gt; 8' />
      </column>
      <column caption='Africa_Only' datatype='string' name='[Calculation_1446719709184000]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] IN (&#13;&#10;&quot;Algeria&quot;,&quot;Angola&quot;,&quot;Benin&quot;,&quot;Botswana&quot;,&quot;Burkina Faso&quot;,&quot;Burundi&quot;,&#13;&#10;&quot;Cabo Verde&quot;,&quot;Cape Verde&quot;,&quot;Cameroon&quot;,&quot;Central African Republic&quot;,&quot;Chad&quot;,&#13;&#10;&quot;Comoros&quot;,&quot;Congo&quot;,&quot;Democratic Republic of the Congo&quot;,&quot;Djibouti&quot;,&quot;Egypt&quot;,&#13;&#10;&quot;Equatorial Guinea&quot;,&quot;Eritrea&quot;,&quot;Eswatini&quot;,&quot;Swaziland&quot;,&quot;Ethiopia&quot;,&quot;Gabon&quot;,&#13;&#10;&quot;Gambia&quot;,&quot;Ghana&quot;,&quot;Guinea&quot;,&quot;Guinea-Bissau&quot;,&quot;Ivory Coast&quot;,&quot;Côte d’Ivoire&quot;,&#13;&#10;&quot;Kenya&quot;,&quot;Lesotho&quot;,&quot;Liberia&quot;,&quot;Libya&quot;,&quot;Madagascar&quot;,&quot;Malawi&quot;,&quot;Mali&quot;,&#13;&#10;&quot;Mauritania&quot;,&quot;Mauritius&quot;,&quot;Morocco&quot;,&quot;Mozambique&quot;,&quot;Namibia&quot;,&quot;Niger&quot;,&#13;&#10;&quot;Nigeria&quot;,&quot;Rwanda&quot;,&quot;Sao Tome and Principe&quot;,&quot;Senegal&quot;,&quot;Seychelles&quot;,&#13;&#10;&quot;Sierra Leone&quot;,&quot;Somalia&quot;,&quot;South Africa&quot;,&quot;South Sudan&quot;,&quot;Sudan&quot;,&#13;&#10;&quot;Tanzania&quot;,&quot;Togo&quot;,&quot;Tunisia&quot;,&quot;Uganda&quot;,&quot;Zambia&quot;,&quot;Zimbabwe&quot;&#13;&#10;)&#13;&#10;THEN &quot;YES&quot;&#13;&#10;ELSE &quot;NO&quot;&#13;&#10;END' />
      </column>
      <column caption='Salary_Min_20K' datatype='integer' name='[Calculation_1446719712043009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#13;&#10;&quot;$&quot;,&quot;&quot;&#13;&#10;),&#13;&#10;&quot;K&quot;,&quot;&quot;&#13;&#10;)&#13;&#10;)' />
      </column>
      <column caption='Salary_Above_20K' datatype='string' name='[Calculation_1446719712145410]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1446719712043009] &gt; 20 THEN &quot;YES&quot; ELSE &quot;NO&quot; END' />
      </column>
      <column caption='Show_3to5PM' datatype='boolean' name='[Calculation_1446719733866501]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] &gt;= 15 AND [Parameters].[Parameter 1] &lt; 17' />
      </column>
      <column caption='Show_3to6PM' datatype='boolean' name='[Calculation_1446719734616070]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] &gt;= 15 AND [Parameters].[Parameter 1] &lt; 18' />
      </column>
