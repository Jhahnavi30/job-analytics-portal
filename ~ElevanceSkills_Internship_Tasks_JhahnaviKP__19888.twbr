              <calculation class='tableau' formula='IF LEFT([Country],1) = &quot;C&quot; THEN &quot;NO&quot;&#13;&#10;&#13;&#10;ELSEIF [Country] IN (&#13;&#10;&quot;Afghanistan&quot;,&quot;Armenia&quot;,&quot;Azerbaijan&quot;,&quot;Bahrain&quot;,&quot;Bangladesh&quot;,&quot;Bhutan&quot;,&quot;Brunei&quot;,&#13;&#10;&quot;Cambodia&quot;,&quot;China&quot;,&quot;Cyprus&quot;,&quot;Georgia&quot;,&quot;India&quot;,&quot;Indonesia&quot;,&quot;Iran&quot;,&quot;Iraq&quot;,&quot;Israel&quot;,&#13;&#10;&quot;Japan&quot;,&quot;Jordan&quot;,&quot;Kazakhstan&quot;,&quot;Kuwait&quot;,&quot;Kyrgyzstan&quot;,&quot;Laos&quot;,&quot;Lebanon&quot;,&quot;Malaysia&quot;,&#13;&#10;&quot;Maldives&quot;,&quot;Mongolia&quot;,&quot;Myanmar&quot;,&quot;Nepal&quot;,&quot;North Korea&quot;,&quot;Oman&quot;,&quot;Pakistan&quot;,&#13;&#10;&quot;Palestine&quot;,&quot;Philippines&quot;,&quot;Qatar&quot;,&quot;Russia&quot;,&quot;Saudi Arabia&quot;,&quot;Singapore&quot;,&#13;&#10;&quot;South Korea&quot;,&quot;Sri Lanka&quot;,&quot;Syria&quot;,&quot;Taiwan&quot;,&quot;Tajikistan&quot;,&quot;Thailand&quot;,&quot;Timor-Leste&quot;,&#13;&#10;&quot;Turkey&quot;,&quot;Turkmenistan&quot;,&quot;United Arab Emirates&quot;,&quot;Uzbekistan&quot;,&quot;Vietnam&quot;,&quot;Yemen&quot;&#13;&#10;) THEN &quot;NO&quot;&#13;&#10;&#13;&#10;ELSE &quot;YES&quot;&#13;&#10;END' />
            </column>
            <column caption='Contact_End_Vowel' datatype='string' name='[Calculation_0975578731040772]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF RIGHT(LOWER([Contact Person]),1) IN (&quot;a&quot;,&quot;e&quot;,&quot;i&quot;,&quot;o&quot;,&quot;u&quot;) THEN &quot;YES&quot;&#13;&#10;ELSE &quot;NO&quot;&#13;&#10;END' />
            </column>
            <column caption='Show_3to5PM' datatype='boolean' name='[Calculation_1446719733866501]' role='dimension' type='nominal'>
